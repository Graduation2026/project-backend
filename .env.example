# =============================================================================
# Sentinel AI — Environment Configuration Template
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# Ghidra installation directory (used inside Docker; override for local dev)
# GHIDRA_INSTALL_DIR=/opt/ghidra

# Google Gemini API key — REQUIRED for RAG report generation and chatbot
# Get one at: https://makersuite.google.com/app/apikey
# GOOGLE_API_KEY=your_gemini_api_key_here

# CORS allowed origins (comma-separated). Leave empty to deny all cross-origin requests.
# CORS_ORIGINS=http://localhost:9090,http://localhost:8000

# Optional API key authentication. Set a value to require X-API-Key header on /analyze.
# SENTINEL_API_KEY=your_admin_key_here

# Ensemble mode and weights
# ENSEMBLE_MODE=hybrid
# ENSEMBLE_GNN_WEIGHT=0.7

# Temp directories
# FEATURES_DIR=./temp/features
# _JAVA_OPTIONS=-Xmx2G
